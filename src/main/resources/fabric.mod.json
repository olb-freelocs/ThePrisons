{
  "schemaVersion": 1,
  "id": "theprisons",
  "version": "0.3",
  "name": "ThePrisons",
  "description": "Client-side Fabric mod for persistent pet and Trinkets cooldown tracking, centered ready announcements, and a clean Mod Menu configuration screen.",
  "authors": [
    "TrustTheCat"
  ],
  "license": "MIT",
  "icon": "assets/theprisons/icon.png",
  "contact": {
    "homepage": "https://github.com/olb-freelocs/ThePrisons",
    "sources": "https://github.com/olb-freelocs/ThePrisons"
  },
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.freelocs.theprisons.ThePrisonsClient"
    ],
    "modmenu": [
      "com.freelocs.theprisons.modmenu.ThePrisonsModMenuIntegration"
    ]
  },
  "mixins": [
    "theprisons.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.17.3",
    "fabric-api": "*",
    "minecraft": "1.21.11",
    "java": ">=21"
  },
  "suggests": {
    "modmenu": "*"
  }
}
